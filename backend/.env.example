PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/rkgadget_store

# STRONG JWT SECRET - never share this!
JWT_SECRET=your_32_character_long_secret_here
JWT_EXPIRE=30d

# RAZORPAY - get from https://razorpay.com
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# STRIPE - get from https://stripe.com
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# EMAIL (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=RK BAZAAR <your_email@gmail.com>

# ADMIN
ADMIN_EMAIL=your_admin_email@gmail.com
CLIENT_URL=http://localhost:5000
