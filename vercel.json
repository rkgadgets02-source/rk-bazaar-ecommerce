{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/server.js" },
    { "source": "/rk-secure-manager.html", "destination": "frontend/rk-secure-manager.html" },
    { "source": "/(.*)", "destination": "frontend/$1" }
  ]
}
