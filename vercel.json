{
  "version": 2,
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/(.*\\.(js|css|html|png|jpg|jpeg|gif|webp|ico|svg|woff|woff2|ttf|eot))", "dest": "frontend/$1" },
    { "src": "/(.*)", "dest": "frontend/index.html" }
  ]
}
